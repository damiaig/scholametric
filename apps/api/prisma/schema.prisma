datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext, pg_trgm]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

enum SchoolType {
  NURSERY_PRIMARY
  SECONDARY
  COMBINED
}

enum SchoolStatus {
  ACTIVE
  SUSPENDED
}

enum UserRole {
  SUPER_ADMIN
  PROPRIETOR
  SCHOOL_ADMIN
  TEACHER
  PARENT
  STUDENT
}

enum JobTitle {
  DIRECTOR_PROPRIETOR
  PRINCIPAL
  VICE_PRINCIPAL
  REGISTRAR
  EXAMINATION_OFFICER
  BURSAR
  SECRETARY
  ICT_ADMINISTRATOR
  SCHOOL_NURSE
  GUIDANCE_COUNSELOR
  TEACHER
  OTHER
}

enum GuardianRelationship {
  FATHER
  MOTHER
  STEPFATHER
  STEPMOTHER
  GRANDPARENT
  UNCLE
  AUNT
  SIBLING
  LEGAL_GUARDIAN
  OTHER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum TermName {
  FIRST
  SECOND
  THIRD
}

enum Gender {
  MALE
  FEMALE
}

enum StudentStatus {
  ACTIVE
  SUSPENDED
  GRADUATED
  TRANSFERRED
  WITHDRAWN
}

model School {
  id        String       @id @default(uuid(7)) @db.Uuid
  name      String
  slug      String       @unique
  type      SchoolType
  address   String?
  phone     String?
  email     String?
  status    SchoolStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  users                     User[]
  academicSessions          AcademicSession[]
  terms                     Term[]
  classLevels               ClassLevel[]
  classArms                 ClassArm[]
  students                  Student[]
  studentEnrollments        StudentEnrollment[]
  auditLogs                 AuditLog[]
  staffProfiles             StaffProfile[]
  subjects                  Subject[]
  subjectClassLevels        SubjectClassLevel[]
  classTeacherAssignments   ClassTeacherAssignment[]
  subjectTeacherAssignments SubjectTeacherAssignment[]
  guardians                 Guardian[]
  studentGuardians          StudentGuardian[]

  @@map("schools")
}

model User {
  id           String     @id @default(uuid(7)) @db.Uuid
  schoolId     String     @map("school_id") @db.Uuid
  email        String     @db.Citext
  passwordHash String     @map("password_hash")
  firstName    String     @map("first_name")
  lastName     String     @map("last_name")
  role         UserRole
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?  @map("last_login_at")
  deletedAt    DateTime?  @map("deleted_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  school                    School                     @relation(fields: [schoolId], references: [id])
  refreshTokens             RefreshToken[]
  auditLogs                 AuditLog[]
  staffProfile              StaffProfile?
  classTeacherAssignments   ClassTeacherAssignment[]
  subjectTeacherAssignments SubjectTeacherAssignment[]

  @@unique([schoolId, email])
  @@index([schoolId])
  @@map("users")
}

// No school_id here by design — a refresh token is only ever reached via
// user_id, and the owning user already carries school_id. See
// docs/DECISIONS.md for the tradeoff against CLAUDE.md §4's general rule.
model RefreshToken {
  id        String    @id @default(uuid(7)) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("refresh_tokens")
}

// Exactly one is_current = true per school is enforced by a partial
// unique index added by hand in the initial migration — Prisma's schema
// DSL can't express partial indexes. See docs/DECISIONS.md.
model AcademicSession {
  id        String   @id @default(uuid(7)) @db.Uuid
  schoolId  String   @map("school_id") @db.Uuid
  name      String
  startsOn  DateTime @map("starts_on") @db.Date
  endsOn    DateTime @map("ends_on") @db.Date
  isCurrent Boolean  @default(false) @map("is_current")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school                    School                     @relation(fields: [schoolId], references: [id])
  terms                     Term[]
  studentEnrollments        StudentEnrollment[]
  classTeacherAssignments   ClassTeacherAssignment[]
  subjectTeacherAssignments SubjectTeacherAssignment[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("academic_sessions")
}

// Exactly one is_current = true per session is enforced by a partial
// unique index added by hand in the initial migration, same as above.
model Term {
  id        String   @id @default(uuid(7)) @db.Uuid
  schoolId  String   @map("school_id") @db.Uuid
  sessionId String   @map("session_id") @db.Uuid
  name      TermName
  startsOn  DateTime @map("starts_on") @db.Date
  endsOn    DateTime @map("ends_on") @db.Date
  isCurrent Boolean  @default(false) @map("is_current")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school  School          @relation(fields: [schoolId], references: [id])
  session AcademicSession @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, name])
  @@index([schoolId])
  @@map("terms")
}

model ClassLevel {
  id        String   @id @default(uuid(7)) @db.Uuid
  schoolId  String   @map("school_id") @db.Uuid
  name      String
  rank      Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school             School              @relation(fields: [schoolId], references: [id])
  classArms          ClassArm[]
  subjectClassLevels SubjectClassLevel[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("class_levels")
}

model ClassArm {
  id           String   @id @default(uuid(7)) @db.Uuid
  schoolId     String   @map("school_id") @db.Uuid
  classLevelId String   @map("class_level_id") @db.Uuid
  name         String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  school                    School                     @relation(fields: [schoolId], references: [id])
  classLevel                ClassLevel                 @relation(fields: [classLevelId], references: [id])
  studentEnrollments        StudentEnrollment[]
  classTeacherAssignments   ClassTeacherAssignment[]
  subjectTeacherAssignments SubjectTeacherAssignment[]

  @@unique([classLevelId, name])
  @@index([schoolId])
  @@map("class_arms")
}

// Trigram index on (first_name, last_name) for ILIKE search added by
// hand in the initial migration — Prisma's index DSL has no way to
// specify the gin_trgm_ops operator class. See docs/DECISIONS.md.
model Student {
  id              String        @id @default(uuid(7)) @db.Uuid
  schoolId        String        @map("school_id") @db.Uuid
  admissionNumber String        @map("admission_number")
  firstName       String        @map("first_name")
  lastName        String        @map("last_name")
  middleName      String?       @map("middle_name")
  gender          Gender
  dateOfBirth     DateTime      @map("date_of_birth") @db.Date
  admittedOn      DateTime      @default(now()) @map("admitted_on") @db.Date
  status          StudentStatus @default(ACTIVE)
  // Frozen as of v0.2 (SPEC_V0.2.md §1): backfilled into guardians/
  // student_guardians by the v0.2 migration, but no longer written by new
  // code. Kept for now — dropping is a future migration once the new
  // tables are verified in production use.
  guardianName    String        @map("guardian_name")
  guardianPhone   String        @map("guardian_phone")
  guardianEmail   String?       @map("guardian_email")
  address         String?
  deletedAt       DateTime?     @map("deleted_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  school           School              @relation(fields: [schoolId], references: [id])
  enrollments      StudentEnrollment[]
  studentGuardians StudentGuardian[]

  @@unique([schoolId, admissionNumber])
  @@index([schoolId])
  @@map("students")
}

model StudentEnrollment {
  id         String   @id @default(uuid(7)) @db.Uuid
  schoolId   String   @map("school_id") @db.Uuid
  studentId  String   @map("student_id") @db.Uuid
  classArmId String   @map("class_arm_id") @db.Uuid
  sessionId  String   @map("session_id") @db.Uuid
  enrolledOn DateTime @default(now()) @map("enrolled_on") @db.Date
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  school   School          @relation(fields: [schoolId], references: [id])
  student  Student         @relation(fields: [studentId], references: [id])
  classArm ClassArm        @relation(fields: [classArmId], references: [id])
  session  AcademicSession @relation(fields: [sessionId], references: [id])

  @@unique([studentId, sessionId])
  @@index([schoolId, classArmId, sessionId])
  @@index([studentId])
  @@map("student_enrollments")
}

model AuditLog {
  id          String   @id @default(uuid(7)) @db.Uuid
  schoolId    String   @map("school_id") @db.Uuid
  actorUserId String   @map("actor_user_id") @db.Uuid
  action      String
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id") @db.Uuid
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  school School @relation(fields: [schoolId], references: [id])
  actor  User   @relation(fields: [actorUserId], references: [id])

  @@index([schoolId])
  @@map("audit_logs")
}

// 1:1 extension of User for every PROPRIETOR/SCHOOL_ADMIN/TEACHER
// (enforced at the service layer, not the DB — v0.2 step 2).
model StaffProfile {
  id            String    @id @default(uuid(7)) @db.Uuid
  schoolId      String    @map("school_id") @db.Uuid
  userId        String    @unique @map("user_id") @db.Uuid
  staffNumber   String    @map("staff_number")
  jobTitle      JobTitle  @map("job_title")
  phone         String?
  qualification String?
  dateEmployed  DateTime? @map("date_employed") @db.Date
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([schoolId, staffNumber])
  @@index([schoolId])
  @@map("staff_profiles")
}

model Subject {
  id        String    @id @default(uuid(7)) @db.Uuid
  schoolId  String    @map("school_id") @db.Uuid
  name      String
  code      String?
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  school             School                     @relation(fields: [schoolId], references: [id])
  classLevels        SubjectClassLevel[]
  teacherAssignments SubjectTeacherAssignment[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("subjects")
}

model SubjectClassLevel {
  id           String   @id @default(uuid(7)) @db.Uuid
  schoolId     String   @map("school_id") @db.Uuid
  subjectId    String   @map("subject_id") @db.Uuid
  classLevelId String   @map("class_level_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  school     School     @relation(fields: [schoolId], references: [id])
  subject    Subject    @relation(fields: [subjectId], references: [id])
  classLevel ClassLevel @relation(fields: [classLevelId], references: [id])

  @@unique([subjectId, classLevelId])
  @@index([schoolId])
  @@map("subject_class_levels")
}

model ClassTeacherAssignment {
  id            String   @id @default(uuid(7)) @db.Uuid
  schoolId      String   @map("school_id") @db.Uuid
  classArmId    String   @map("class_arm_id") @db.Uuid
  sessionId     String   @map("session_id") @db.Uuid
  teacherUserId String   @map("teacher_user_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  school      School          @relation(fields: [schoolId], references: [id])
  classArm    ClassArm        @relation(fields: [classArmId], references: [id])
  session     AcademicSession @relation(fields: [sessionId], references: [id])
  teacherUser User            @relation(fields: [teacherUserId], references: [id])

  @@unique([classArmId, sessionId])
  @@index([schoolId])
  @@map("class_teacher_assignments")
}

model SubjectTeacherAssignment {
  id            String   @id @default(uuid(7)) @db.Uuid
  schoolId      String   @map("school_id") @db.Uuid
  subjectId     String   @map("subject_id") @db.Uuid
  classArmId    String   @map("class_arm_id") @db.Uuid
  sessionId     String   @map("session_id") @db.Uuid
  teacherUserId String   @map("teacher_user_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  school      School          @relation(fields: [schoolId], references: [id])
  subject     Subject         @relation(fields: [subjectId], references: [id])
  classArm    ClassArm        @relation(fields: [classArmId], references: [id])
  session     AcademicSession @relation(fields: [sessionId], references: [id])
  teacherUser User            @relation(fields: [teacherUserId], references: [id])

  @@unique([subjectId, classArmId, sessionId])
  @@index([schoolId, teacherUserId, sessionId])
  @@map("subject_teacher_assignments")
}

model Guardian {
  id        String    @id @default(uuid(7)) @db.Uuid
  schoolId  String    @map("school_id") @db.Uuid
  firstName String    @map("first_name")
  lastName  String    @map("last_name")
  phone     String
  email     String?
  address   String?
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  school           School            @relation(fields: [schoolId], references: [id])
  studentGuardians StudentGuardian[]

  @@index([schoolId])
  @@map("guardians")
}

// Exactly one is_primary = true per student is enforced by a partial
// unique index added by hand in this migration — same pattern as v0.1's
// academic_sessions/terms current-flag indexes. See docs/DECISIONS.md.
model StudentGuardian {
  id           String               @id @default(uuid(7)) @db.Uuid
  schoolId     String               @map("school_id") @db.Uuid
  studentId    String               @map("student_id") @db.Uuid
  guardianId   String               @map("guardian_id") @db.Uuid
  relationship GuardianRelationship
  isPrimary    Boolean              @default(false) @map("is_primary")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  school   School   @relation(fields: [schoolId], references: [id])
  student  Student  @relation(fields: [studentId], references: [id])
  guardian Guardian @relation(fields: [guardianId], references: [id])

  @@unique([studentId, guardianId])
  @@index([schoolId])
  @@map("student_guardians")
}
