# docker-compose level configuration (host ports intentionally non-default
# to avoid clashing with locally installed Postgres/Redis instances)
POSTGRES_USER=scholametric
POSTGRES_PASSWORD=scholametric
POSTGRES_DB=scholametric
POSTGRES_PORT=5433
REDIS_PORT=6380
API_PORT=3000
WEB_PORT=5173

# 32+ char random secrets, distinct per environment, e.g. `openssl rand -hex 48`
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
